# Copy to frontend/.env.local (gitignored).

# Vapi voice agent. Get a free PUBLIC key at https://dashboard.vapi.ai
# (Settings, API Keys, "Public key" - safe for the browser, unlike the private key).
# The Voice button in the header stays disabled until this is set.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Backend URL override (defaults to http://127.0.0.1:8000).
# NEXT_PUBLIC_API_URL=
